# -----------------------------------------------------------------------
# Touch Grass Bot — Environment Variables
# Copy this file to .env for local development.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# REQUIRED — get this from @BotFather on Telegram
BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED — the numeric ID of the group where the bot should operate
# Negative number for groups (e.g. -1001234567890)
ALLOWED_CHAT_ID=-1001234567890

# How often (in minutes) to announce the most active user
# Default: 30
TOUCH_GRASS_INTERVAL_MINUTES=30

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Optional AI reminder generation with OpenAI
# If OPENAI_API_KEY is set, AI reminders are enabled by default.
# -----------------------------------------------------------------------

# OPTIONAL — OpenAI API key for fresh generated reminder lines
OPENAI_API_KEY=

# OPTIONAL — turn AI reminders on/off explicitly
# Default: true when OPENAI_API_KEY is set, otherwise false
AI_REMINDERS_ENABLED=

# OPTIONAL — model used for reminder generation
# Default: gpt-5.4-mini
OPENAI_MODEL=gpt-5.4-mini

# OPTIONAL — moderate generated reminders before posting
# Default: true
AI_MODERATION_ENABLED=true

# OPTIONAL — how many recent AI messages to remember for deduping
# Default: 20
AI_RECENT_MESSAGES_LIMIT=20
